# Copy to .env and fill in to run the opt-in integration tests:
#   npm run test:integration

# Enables the integration suites (they are skipped otherwise).
INDIGODB_INTEGRATION=1

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_user
PG_PASSWORD=your_password
PG_DATABASE=indigodb_test
PG_TEST_WS_PORT=8091

# --- MongoDB (must be a replica set for change streams) ---
MONGO_URL=mongodb://localhost:27017/indigodb_test
MONGO_TEST_WS_PORT=8092
